{
  "name": "unipet-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw hook connector for the UniPet desktop pet",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "install": {
      "defaultChoice": "local",
      "minHostVersion": ">=2026.3.22"
    }
  }
}
